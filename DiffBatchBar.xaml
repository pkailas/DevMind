<UserControl x:Class="DevMind.DiffBatchBar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Margin="0,2,0,4">
    <Border Background="#FF333337"
            BorderBrush="#FF3E3E42"
            BorderThickness="1"
            CornerRadius="4"
            Padding="8,6">
        <StackPanel Orientation="Horizontal"
                    HorizontalAlignment="Center">
            <Button x:Name="ApplyAllButton"
                    Content="&#x2713; Apply All"
                    MinWidth="90"
                    Margin="0,0,12,0"
                    Padding="8,4"
                    FontSize="11"
                    Click="ApplyAllButton_Click" />
            <Button x:Name="SkipAllButton"
                    Content="&#x2717; Skip All"
                    MinWidth="90"
                    Padding="8,4"
                    FontSize="11"
                    Click="SkipAllButton_Click" />
        </StackPanel>
    </Border>
</UserControl>
