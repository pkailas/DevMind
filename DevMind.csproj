<Project>

  <!-- Import SDK props first -->
  <Import Project="Sdk.props" Sdk="Microsoft.NET.Sdk" />

  <PropertyGroup>
    <TargetFramework>net48</TargetFramework>
    <LangVersion>8.0</LangVersion>
    <RootNamespace>DevMind</RootNamespace>
    <AssemblyName>DevMind</AssemblyName>
    <UseWPF>true</UseWPF>
    <!-- VSIX packaging -->
    <CreateVsixContainer>true</CreateVsixContainer>
    <DeployExtension Condition="'$(Configuration)' == 'Release'">false</DeployExtension>
    <GeneratePkgDefFile>true</GeneratePkgDefFile>
    <UseCodebase>true</UseCodebase>
    <IncludeAssemblyInVSIXContainer>true</IncludeAssemblyInVSIXContainer>
    <IncludeDebugSymbolsInVSIXContainer>false</IncludeDebugSymbolsInVSIXContainer>
    <IncludeDebugSymbolsInLocalVSIXDeployment>true</IncludeDebugSymbolsInLocalVSIXDeployment>
    <CopyBuildOutputToOutputDirectory>true</CopyBuildOutputToOutputDirectory>
    <CopyOutputSymbolsToOutputDirectory>true</CopyOutputSymbolsToOutputDirectory>
    <StartAction>Program</StartAction>
    <StartProgram Condition="'$(DevEnvDir)' != ''">$(DevEnvDir)devenv.exe</StartProgram>
    <StartArguments>/rootsuffix Exp</StartArguments>
    <!-- Suppress auto-generated AssemblyInfo since we have Properties/AssemblyInfo.cs -->
    <GenerateAssemblyInfo>false</GenerateAssemblyInfo>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.VisualStudio.SDK" Version="17.0.32112.339" ExcludeAssets="runtime" />
    <PackageReference Include="Microsoft.VSSDK.BuildTools" Version="17.14.2120">
      <IncludeAssets>build; buildTransitive; contentFiles; analyzers</IncludeAssets>
      <PrivateAssets>all</PrivateAssets>
    </PackageReference>
    <PackageReference Include="Community.VisualStudio.Toolkit.17" Version="17.0.549" />
    <PackageReference Include="Newtonsoft.Json" Version="13.0.1" />
    <PackageReference Include="Microsoft.Extensions.Http" Version="3.1.8" />
  </ItemGroup>

  <ItemGroup>
    <None Include="source.extension.vsixmanifest" SubType="Designer" />
  </ItemGroup>

  <ItemGroup>
    <VSCTCompile Include="DevMindCommandTable.vsct">
      <ResourceName>Menus.ctmenu</ResourceName>
    </VSCTCompile>
  </ItemGroup>

  <ItemGroup>
    <Reference Include="System.Net.Http" />
  </ItemGroup>

  <!-- Import SDK targets to set TargetName, OutDir, IntermediateOutputPath, etc. -->
  <Import Project="Sdk.targets" Sdk="Microsoft.NET.Sdk" />

  <!-- Import VSSDK targets AFTER SDK targets so VSIX properties resolve correctly -->
  <Import Project="$(VSToolsPath)\VSSDK\Microsoft.VsSDK.targets" Condition="'$(VSToolsPath)' != ''" />

  <!-- 1. Increment build counter, stamp AssemblyInfo and manifests before compile -->
  <Target Name="IncrementBuildCounter" BeforeTargets="BeforeBuild">
    <PropertyGroup>
      <BuildCounterFile>$(MSBuildProjectDirectory)\build.counter</BuildCounterFile>
    </PropertyGroup>
    <ReadLinesFromFile File="$(BuildCounterFile)" Condition="Exists('$(BuildCounterFile)')">
      <Output TaskParameter="Lines" ItemName="CounterLines" />
    </ReadLinesFromFile>
    <PropertyGroup>
      <CurrentCounter Condition="'@(CounterLines)' != ''">@(CounterLines)</CurrentCounter>
      <CurrentCounter Condition="'$(CurrentCounter)' == ''">0</CurrentCounter>
      <NextCounter>$([MSBuild]::Add($(CurrentCounter), 1))</NextCounter>
      <NextCounter Condition="'$([System.Convert]::ToInt32($(NextCounter)))' &gt; '65535'">1</NextCounter>
      <VsixVersion>6.0.$(NextCounter)</VsixVersion>
    </PropertyGroup>
    <WriteLinesToFile File="$(BuildCounterFile)" Lines="$(NextCounter)" Overwrite="true" />
    <XmlPoke XmlInputPath="$(MSBuildProjectDirectory)\source.extension.vsixmanifest"
             Namespaces="&lt;Namespace Prefix='vs' Uri='http://schemas.microsoft.com/developer/vsx-schema/2011'/&gt;"
             Query="/vs:PackageManifest/vs:Metadata/vs:Identity/@Version"
             Value="$(VsixVersion)" />
    <XmlPoke XmlInputPath="$(MSBuildProjectDirectory)\extension.vsixmanifest"
             Namespaces="&lt;Namespace Prefix='vs' Uri='http://schemas.microsoft.com/developer/vsx-schema/2011'/&gt;"
             Query="/vs:PackageManifest/vs:Metadata/vs:Identity/@Version"
             Value="$(VsixVersion)" />
    <XmlPoke XmlInputPath="$(OutputPath)extension.vsixmanifest"
             Namespaces="&lt;Namespace Prefix='vs' Uri='http://schemas.microsoft.com/developer/vsx-schema/2011'/&gt;"
             Query="/vs:PackageManifest/vs:Metadata/vs:Identity/@Version"
             Value="$(VsixVersion)"
             Condition="Exists('$(OutputPath)extension.vsixmanifest')" />
    <XmlPoke XmlInputPath="$(IntermediateOutputPath)extension.vsixmanifest"
             Namespaces="&lt;Namespace Prefix='vs' Uri='http://schemas.microsoft.com/developer/vsx-schema/2011'/&gt;"
             Query="/vs:PackageManifest/vs:Metadata/vs:Identity/@Version"
             Value="$(VsixVersion)"
             Condition="Exists('$(IntermediateOutputPath)extension.vsixmanifest')" />
    <!-- Stamp AssemblyInfo.cs: replace AssemblyVersion / AssemblyFileVersion lines -->
    <PropertyGroup>
      <AssemblyInfoFile>$(MSBuildProjectDirectory)\Properties\AssemblyInfo.cs</AssemblyInfoFile>
      <AssemblyVersionFull>$(VsixVersion).0</AssemblyVersionFull>
    </PropertyGroup>
    <ReadLinesFromFile File="$(AssemblyInfoFile)">
      <Output TaskParameter="Lines" ItemName="AssemblyInfoLines" />
    </ReadLinesFromFile>
    <ItemGroup>
      <AssemblyInfoLinesUpdated Include="@(AssemblyInfoLines)">
        <Line>$([System.Text.RegularExpressions.Regex]::Replace('%(AssemblyInfoLines.Identity)', 'AssemblyVersion\("[\d\.]+"\)', 'AssemblyVersion("$(AssemblyVersionFull)")'))</Line>
      </AssemblyInfoLinesUpdated>
      <AssemblyInfoLinesUpdated2 Include="@(AssemblyInfoLinesUpdated)">
        <Line>$([System.Text.RegularExpressions.Regex]::Replace('%(AssemblyInfoLinesUpdated.Line)', 'AssemblyFileVersion\("[\d\.]+"\)', 'AssemblyFileVersion("$(AssemblyVersionFull)")'))</Line>
      </AssemblyInfoLinesUpdated2>
    </ItemGroup>
    <WriteLinesToFile File="$(AssemblyInfoFile)" Lines="@(AssemblyInfoLinesUpdated2->'%(Line)')" Overwrite="true" />
    <Message Text="AssemblyInfo version stamped: $(AssemblyVersionFull)" Importance="high" />
    <Message Text="VSIX version stamped: $(VsixVersion)" Importance="high" />
  </Target>

  <!-- 2. Re-apply manifest version just before VSIX packaging (no counter increment) -->
  <Target Name="StampVsixManifests" BeforeTargets="CreateVsixContainer">
    <PropertyGroup>
      <BuildCounterFile>$(MSBuildProjectDirectory)\build.counter</BuildCounterFile>
    </PropertyGroup>
    <ReadLinesFromFile File="$(BuildCounterFile)" Condition="Exists('$(BuildCounterFile)')">
      <Output TaskParameter="Lines" ItemName="ManifestCounterLines" />
    </ReadLinesFromFile>
    <PropertyGroup>
      <ManifestCounter Condition="'@(ManifestCounterLines)' != ''">@(ManifestCounterLines)</ManifestCounter>
      <ManifestCounter Condition="'$(ManifestCounter)' == ''">0</ManifestCounter>
      <VsixVersion Condition="'$(VsixVersion)' == ''">6.0.$(ManifestCounter)</VsixVersion>
    </PropertyGroup>
    <XmlPoke XmlInputPath="$(MSBuildProjectDirectory)\source.extension.vsixmanifest"
             Namespaces="&lt;Namespace Prefix='vs' Uri='http://schemas.microsoft.com/developer/vsx-schema/2011'/&gt;"
             Query="/vs:PackageManifest/vs:Metadata/vs:Identity/@Version"
             Value="$(VsixVersion)" />
    <XmlPoke XmlInputPath="$(MSBuildProjectDirectory)\extension.vsixmanifest"
             Namespaces="&lt;Namespace Prefix='vs' Uri='http://schemas.microsoft.com/developer/vsx-schema/2011'/&gt;"
             Query="/vs:PackageManifest/vs:Metadata/vs:Identity/@Version"
             Value="$(VsixVersion)" />
    <XmlPoke XmlInputPath="$(OutputPath)extension.vsixmanifest"
             Namespaces="&lt;Namespace Prefix='vs' Uri='http://schemas.microsoft.com/developer/vsx-schema/2011'/&gt;"
             Query="/vs:PackageManifest/vs:Metadata/vs:Identity/@Version"
             Value="$(VsixVersion)"
             Condition="Exists('$(OutputPath)extension.vsixmanifest')" />
    <XmlPoke XmlInputPath="$(IntermediateOutputPath)extension.vsixmanifest"
             Namespaces="&lt;Namespace Prefix='vs' Uri='http://schemas.microsoft.com/developer/vsx-schema/2011'/&gt;"
             Query="/vs:PackageManifest/vs:Metadata/vs:Identity/@Version"
             Value="$(VsixVersion)"
             Condition="Exists('$(IntermediateOutputPath)extension.vsixmanifest')" />
    <!-- Stamp manifest.json in the intermediate output folder -->
    <PropertyGroup>
      <ManifestJsonFile>$(IntermediateOutputPath)manifest.json</ManifestJsonFile>
    </PropertyGroup>
    <ReadLinesFromFile File="$(ManifestJsonFile)" Condition="Exists('$(ManifestJsonFile)')">
      <Output TaskParameter="Lines" ItemName="ManifestJsonLines" />
    </ReadLinesFromFile>
    <ItemGroup>
      <ManifestJsonLinesUpdated Include="@(ManifestJsonLines)">
        <Line>$([System.Text.RegularExpressions.Regex]::Replace('%(ManifestJsonLines.Identity)', '"version"\s*:\s*"[\d\.]+"', '"version":"$(VsixVersion)"'))</Line>
      </ManifestJsonLinesUpdated>
    </ItemGroup>
    <WriteLinesToFile File="$(ManifestJsonFile)"
                     Lines="@(ManifestJsonLinesUpdated->'%(Line)')"
                     Overwrite="true"
                     Condition="Exists('$(ManifestJsonFile)')" />
    <Message Text="manifest.json version stamped: $(VsixVersion)" Importance="high" />
    <Message Text="VSIX manifests re-stamped for packaging: $(VsixVersion)" Importance="high" />
  </Target>

</Project>
