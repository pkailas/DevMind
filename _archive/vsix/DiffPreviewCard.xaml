<UserControl x:Class="DevMind.DiffPreviewCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Margin="0,4,0,4">
    <Border Background="#FF2D2D30"
            BorderBrush="#FF3E3E42"
            BorderThickness="1"
            CornerRadius="4"
            Padding="0">

        <StackPanel>
            <!-- Header -->
            <Border Background="#FF333337"
                    CornerRadius="4,4,0,0"
                    Padding="8,6">
                <StackPanel Orientation="Horizontal">
                    <TextBlock x:Name="HeaderText"
                               FontFamily="Consolas"
                               FontSize="11"
                               FontWeight="SemiBold"
                               Foreground="#FFCCCCCC"
                               Text="PATCH — filename.cs" />
                    <Border x:Name="ConfidenceBadge"
                            Background="#FF2E7D32"
                            CornerRadius="3"
                            Padding="6,2"
                            Margin="8,0,0,0">
                        <TextBlock x:Name="ConfidenceText"
                                   FontFamily="Consolas"
                                   FontSize="10"
                                   Foreground="#FFFFFFFF"
                                   Text="Exact" />
                    </Border>
                </StackPanel>
            </Border>

            <!-- Separator -->
            <Border Height="1" Background="#FF3E3E42" />

            <!-- Diff content -->
            <ItemsControl x:Name="DiffLines"
                          Background="#FF1E1E1E"
                          Padding="0">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="{Binding Background}" Padding="8,1,8,1">
                            <TextBlock Text="{Binding Text}"
                                       FontFamily="Consolas"
                                       FontSize="10"
                                       Foreground="{Binding Foreground}" />
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- Separator -->
            <Border Height="1" Background="#FF3E3E42" />

            <!-- Buttons -->
            <Border Background="#FF333337"
                    CornerRadius="0,0,4,4"
                    Padding="8,6">
                <StackPanel x:Name="ButtonPanel"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right">
                    <Button x:Name="ApplyButton"
                            Content="&#x2713; Apply"
                            MinWidth="70"
                            Margin="0,0,8,0"
                            Padding="8,4"
                            FontSize="11"
                            Click="ApplyButton_Click" />
                    <Button x:Name="SkipButton"
                            Content="&#x2717; Skip"
                            MinWidth="70"
                            Padding="8,4"
                            FontSize="11"
                            Click="SkipButton_Click" />
                </StackPanel>
            </Border>
        </StackPanel>
    </Border>
</UserControl>
