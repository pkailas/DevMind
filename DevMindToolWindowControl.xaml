<UserControl x:Class="DevMind.DevMindToolWindowControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:DevMind"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="350">
    <Grid Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />   <!-- Row 0: System prompt collapsible -->
            <RowDefinition Height="Auto" />   <!-- Row 1: Input area -->
            <RowDefinition Height="Auto" />   <!-- Row 2: Toolbar -->
            <RowDefinition Height="*" />      <!-- Row 3: Output stream -->
        </Grid.RowDefinitions>

        <!-- Row 0: Collapsible system prompt panel -->
        <StackPanel Grid.Row="0">
            <ToggleButton x:Name="SystemPromptToggle"
                          Content="System Prompt &#x25BC;"
                          IsChecked="False"
                          HorizontalAlignment="Stretch"
                          HorizontalContentAlignment="Left"
                          Padding="6,4"
                          FontSize="11"
                          BorderThickness="0,0,0,1"
                          BorderBrush="{DynamicResource {x:Static SystemColors.ActiveBorderBrushKey}}"
                          Checked="SystemPromptToggle_Checked"
                          Unchecked="SystemPromptToggle_Unchecked" />
            <Border x:Name="SystemPromptPanel"
                    Visibility="Collapsed"
                    MaxHeight="150"
                    Padding="4"
                    BorderThickness="0,0,0,1"
                    BorderBrush="{DynamicResource {x:Static SystemColors.ActiveBorderBrushKey}}">
                <TextBox x:Name="SystemPromptTextBox"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         MinHeight="60"
                         MaxHeight="140"
                         VerticalScrollBarVisibility="Auto"
                         Padding="4,2"
                         FontSize="11"
                         TextChanged="SystemPromptTextBox_TextChanged" />
            </Border>
        </StackPanel>

        <!-- Row 1: Input area -->
        <Border Grid.Row="1"
                BorderThickness="1"
                BorderBrush="{DynamicResource {x:Static SystemColors.ActiveBorderBrushKey}}"
                Margin="4,4,4,0">
            <TextBox x:Name="InputTextBox"
                     TextWrapping="Wrap"
                     MinHeight="120"
                     MaxHeight="200"
                     VerticalScrollBarVisibility="Auto"
                     Padding="6,4"
                     AcceptsReturn="True"
                     FontSize="12"
                     PreviewKeyDown="InputTextBox_KeyDown" />
        </Border>

        <!-- Row 2: Toolbar -->
        <Grid Grid.Row="2" Margin="4,2,4,2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <Button x:Name="AskButton" Grid.Column="0" Content="Ask" MinWidth="50" Margin="0,0,4,0" Click="AskButton_Click" />
            <Button x:Name="RunButton" Grid.Column="1" Content="Run" MinWidth="50" Margin="0,0,4,0" Click="RunButton_Click" />
            <Button x:Name="StopButton" Grid.Column="2" Content="&#x25A0; Stop" MinWidth="50" Margin="0,0,4,0" IsEnabled="False" Click="StopButton_Click" />
            <Button x:Name="RestartButton" Grid.Column="3" Content="Restart" MinWidth="55" Margin="0,0,4,0" Click="RestartButton_Click" />
            <Button x:Name="ClearButton" Grid.Column="4" Content="Clear" MinWidth="50" Margin="0,0,4,0" Click="ClearButton_Click" />
            <Button x:Name="ClearPromptButton" Grid.Column="5" Content="⌫" MinWidth="28" Margin="0,0,4,0" Click="ClearPromptButton_Click" ToolTip="Clear prompt" />
            <TextBlock x:Name="ContextIndicator"
                       Grid.Column="6"
                       VerticalAlignment="Center"
                       Padding="4,0"
                       FontSize="10"
                       Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}"
                       Text="" />
            <TextBlock x:Name="StatusText"
                       Grid.Column="7"
                       VerticalAlignment="Center"
                       Padding="4,0"
                       FontSize="10"
                       Text="Ready" />
        </Grid>

        <!-- Row 3: Output stream -->
        <RichTextBox x:Name="OutputBox"
                     Grid.Row="3"
                     IsReadOnly="True"
                     IsReadOnlyCaretVisible="True"
                     VerticalScrollBarVisibility="Auto"
                     HorizontalScrollBarVisibility="Auto"
                     FontFamily="Consolas"
                     FontSize="12"
                     Background="#FF1E1E1E"
                     Foreground="#FFCCCCCC"
                     BorderThickness="0"
                     Padding="6,4"
                     Margin="4,2,4,2" />
    </Grid>
</UserControl>
