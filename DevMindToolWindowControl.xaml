<UserControl x:Class="DevMind.DevMindToolWindowControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="350">
    <Grid Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Scrollable chat message history -->
        <ScrollViewer Grid.Row="0"
                      x:Name="ChatScrollViewer"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Padding="4">
            <ItemsControl x:Name="MessagesPanel">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Padding="8,6"
                                Margin="4,3"
                                CornerRadius="6"
                                HorizontalAlignment="{Binding Alignment}"
                                Background="{Binding Background}"
                                MaxWidth="300">
                            <TextBlock Text="{Binding Text}"
                                       TextWrapping="Wrap"
                                       Foreground="{Binding Foreground}"
                                       FontSize="12" />
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Input area with Send and Clear buttons -->
        <Grid Grid.Row="1" Margin="4,2,4,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBox Grid.Column="0"
                     x:Name="InputTextBox"
                     AcceptsReturn="False"
                     TextWrapping="Wrap"
                     MaxHeight="100"
                     MinHeight="28"
                     VerticalScrollBarVisibility="Auto"
                     VerticalContentAlignment="Center"
                     Padding="4,2"
                     KeyDown="InputTextBox_KeyDown" />
            <Button Grid.Column="1"
                    x:Name="SendButton"
                    Content="Send"
                    Width="54"
                    MinHeight="28"
                    Margin="4,0,0,0"
                    Click="SendButton_Click" />
            <Button Grid.Column="2"
                    x:Name="ClearButton"
                    Content="Clear"
                    Width="54"
                    MinHeight="28"
                    Margin="4,0,0,0"
                    Click="ClearButton_Click" />
        </Grid>

        <!-- Status bar -->
        <Border Grid.Row="2"
                Padding="6,3"
                BorderThickness="0,1,0,0"
                BorderBrush="{DynamicResource {x:Static SystemColors.ActiveBorderBrushKey}}">
            <TextBlock x:Name="StatusText"
                       Text="Disconnected"
                       FontSize="11"
                       Opacity="0.8" />
        </Border>
    </Grid>
</UserControl>
