<UserControl x:Class="DevMind.DevMindToolWindowControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:DevMind"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="350">
    <UserControl.Resources>
        <local:WidthPercentageConverter x:Key="WidthPctConverter" />
    </UserControl.Resources>
    <Grid Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Collapsible system prompt panel -->
        <StackPanel Grid.Row="0">
            <ToggleButton x:Name="SystemPromptToggle"
                          Content="System Prompt &#x25BC;"
                          IsChecked="False"
                          HorizontalAlignment="Stretch"
                          HorizontalContentAlignment="Left"
                          Padding="6,4"
                          FontSize="11"
                          BorderThickness="0,0,0,1"
                          BorderBrush="{DynamicResource {x:Static SystemColors.ActiveBorderBrushKey}}"
                          Checked="SystemPromptToggle_Checked"
                          Unchecked="SystemPromptToggle_Unchecked" />
            <Border x:Name="SystemPromptPanel"
                    Visibility="Collapsed"
                    Padding="4"
                    BorderThickness="0,0,0,1"
                    BorderBrush="{DynamicResource {x:Static SystemColors.ActiveBorderBrushKey}}">
                <TextBox x:Name="SystemPromptTextBox"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         MinHeight="60"
                         MaxHeight="140"
                         VerticalScrollBarVisibility="Auto"
                         Padding="4,2"
                         FontSize="11"
                         TextChanged="SystemPromptTextBox_TextChanged" />
            </Border>
        </StackPanel>

        <!-- Scrollable chat message history -->
        <ScrollViewer Grid.Row="1"
                      x:Name="ChatScrollViewer"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Padding="4">
            <ItemsControl x:Name="MessagesPanel">
                <!-- Stretch each item so assistant messages can span the full width -->
                <ItemsControl.ItemContainerStyle>
                    <Style TargetType="ContentPresenter">
                        <Setter Property="HorizontalAlignment" Value="Stretch" />
                    </Style>
                </ItemsControl.ItemContainerStyle>

                <ItemsControl.Resources>

                    <!-- ── User message: right-aligned blue bubble ── -->
                    <DataTemplate DataType="{x:Type local:UserMessageViewModel}">
                        <Border Padding="8,6"
                                Margin="4,3"
                                CornerRadius="6"
                                HorizontalAlignment="Right"
                                Background="#FF007ACC"
                                MaxWidth="{Binding ActualWidth,
                                           RelativeSource={RelativeSource AncestorType=ScrollViewer},
                                           Converter={StaticResource WidthPctConverter},
                                           ConverterParameter=0.9}">
                            <TextBox Text="{Binding Text, Mode=OneWay}"
                                     TextWrapping="Wrap"
                                     Foreground="White"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     IsReadOnly="True"
                                     IsReadOnlyCaretVisible="False"
                                     Padding="0"
                                     FontSize="12"
                                     Cursor="Arrow" />
                        </Border>
                    </DataTemplate>

                    <!-- ── Assistant message: vertical stack of text / code segments ── -->
                    <DataTemplate DataType="{x:Type local:AssistantMessageViewModel}">
                        <ItemsControl ItemsSource="{Binding Segments}"
                                      Margin="4,3"
                                      HorizontalAlignment="Left"
                                      MaxWidth="{Binding ActualWidth,
                                                 RelativeSource={RelativeSource AncestorType=ScrollViewer},
                                                 Converter={StaticResource WidthPctConverter},
                                                 ConverterParameter=0.95}">
                            <ItemsControl.ItemContainerStyle>
                                <Style TargetType="ContentPresenter">
                                    <Setter Property="HorizontalAlignment" Value="Stretch" />
                                </Style>
                            </ItemsControl.ItemContainerStyle>

                            <ItemsControl.Resources>

                                <!-- Text segment: gray bubble with selectable markdown rendering -->
                                <DataTemplate DataType="{x:Type local:TextSegmentViewModel}">
                                    <Border Padding="8,6"
                                            Margin="0,2"
                                            CornerRadius="6"
                                            HorizontalAlignment="Left"
                                            Background="#FF3C3C3C"
                                            MaxWidth="{Binding ActualWidth,
                                                       RelativeSource={RelativeSource AncestorType=ScrollViewer},
                                                       Converter={StaticResource WidthPctConverter},
                                                       ConverterParameter=0.9}">
                                        <local:MarkdownRichTextBox
                                                 MarkdownText="{Binding Text, Mode=OneWay}"
                                                 Foreground="#FFDCDCDC"
                                                 Background="Transparent"
                                                 BorderThickness="0"
                                                 Padding="0"
                                                 FontSize="12" />
                                    </Border>
                                </DataTemplate>

                                <!-- Code segment: dark VS Code-style code box -->
                                <DataTemplate DataType="{x:Type local:CodeSegmentViewModel}">
                                    <Border Margin="0,2"
                                            BorderThickness="1"
                                            BorderBrush="#FF3E3E3E"
                                            HorizontalAlignment="Stretch">
                                        <StackPanel>

                                            <!-- Header bar: language label + Copy button -->
                                            <Border Background="#FF2D2D2D" Padding="8,4">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Grid.Column="0"
                                                               Text="{Binding Language}"
                                                               Foreground="#FF9CDCFE"
                                                               FontFamily="Consolas"
                                                               FontSize="11"
                                                               VerticalAlignment="Center" />
                                                    <Button Grid.Column="1"
                                                            Content="Copy"
                                                            Command="{Binding CopyCommand}"
                                                            Padding="8,2"
                                                            FontSize="11"
                                                            Cursor="Hand" />
                                                </Grid>
                                            </Border>

                                            <!-- Code content: monospace, dark background, selectable -->
                                            <TextBox Text="{Binding Code, Mode=OneWay}"
                                                     Background="#FF1E1E1E"
                                                     Foreground="#FFD4D4D4"
                                                     FontFamily="Consolas"
                                                     FontSize="12"
                                                     IsReadOnly="True"
                                                     IsReadOnlyCaretVisible="False"
                                                     BorderThickness="0"
                                                     Padding="8,6"
                                                     TextWrapping="NoWrap"
                                                     HorizontalScrollBarVisibility="Auto"
                                                     VerticalScrollBarVisibility="Disabled"
                                                     AcceptsReturn="True"
                                                     Cursor="Arrow" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>

                            </ItemsControl.Resources>
                        </ItemsControl>
                    </DataTemplate>

                </ItemsControl.Resources>
            </ItemsControl>
        </ScrollViewer>

        <!-- Input area with Send and Clear buttons -->
        <Grid Grid.Row="2" Margin="4,2,4,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBox Grid.Column="0"
                     x:Name="InputTextBox"
                     AcceptsReturn="False"
                     TextWrapping="Wrap"
                     MaxHeight="100"
                     MinHeight="28"
                     VerticalScrollBarVisibility="Auto"
                     VerticalContentAlignment="Center"
                     Padding="4,2"
                     KeyDown="InputTextBox_KeyDown" />
            <Button Grid.Column="1"
                    x:Name="SendButton"
                    Content="Send"
                    Width="54"
                    MinHeight="28"
                    Margin="4,0,0,0"
                    Click="SendButton_Click" />
            <Button Grid.Column="2"
                    x:Name="ClearButton"
                    Content="Clear"
                    Width="54"
                    MinHeight="28"
                    Margin="4,0,0,0"
                    Click="ClearButton_Click" />
        </Grid>

        <!-- Status bar -->
        <Border Grid.Row="3"
                Padding="6,3"
                BorderThickness="0,1,0,0"
                BorderBrush="{DynamicResource {x:Static SystemColors.ActiveBorderBrushKey}}">
            <TextBlock x:Name="StatusText"
                       Text="Disconnected"
                       FontSize="11"
                       Opacity="0.8" />
        </Border>
    </Grid>
</UserControl>
