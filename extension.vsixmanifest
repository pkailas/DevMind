<PackageManifest Version="2.0.0" xmlns="http://schemas.microsoft.com/developer/vsx-schema/2011">
  <Metadata>
    <Identity Id="DevMind.LocalLLMAssistant" Version="6.0.94" Language="en-US" Publisher="iOnline Consulting LLC" />
    <DisplayName>DevMind</DisplayName>
    <Description xml:space="preserve">Local LLM coding assistant for Visual Studio. Supports any OpenAI-compatible endpoint including LM Studio and Ollama. 100% private - no code leaves your machine.</Description>
    <Tags>AI, LLM, local, privacy, coding assistant</Tags>
  </Metadata>
  <Installation>
    <InstallationTarget Id="Microsoft.VisualStudio.Community" Version="[17.0,20.0)">
      <ProductArchitecture>amd64</ProductArchitecture>
    </InstallationTarget>
    <InstallationTarget Id="Microsoft.VisualStudio.Pro" Version="[17.0,20.0)">
      <ProductArchitecture>amd64</ProductArchitecture>
    </InstallationTarget>
  </Installation>
  <Dependencies>
    <Dependency Id="Microsoft.Framework.NDP" DisplayName="Microsoft .NET Framework" Version="[4.5,)" />
  </Dependencies>
  <Prerequisites>
    <Prerequisite Id="Microsoft.VisualStudio.Component.CoreEditor" Version="[17.0,20.0)" DisplayName="Visual Studio core editor" />
  </Prerequisites>
  <Assets>
    <Asset Type="Microsoft.VisualStudio.VsPackage" Path="DevMind.pkgdef" />
  </Assets>
</PackageManifest>